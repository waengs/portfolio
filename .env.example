# Firebase — create a project at https://console.firebase.google.com
# Enable Firestore + Email/Password Auth, then paste your web app config here.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# After creating your admin account, copy your UID from Firebase Auth
# and replace REPLACE_WITH_YOUR_FIREBASE_UID in firestore.rules, then deploy rules.
